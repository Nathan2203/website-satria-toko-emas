# Salin file ini menjadi ".env" untuk development di komputer lokal.
# Di Render, isi nilai-nilai ini lewat tab "Environment" pada dashboard (bukan file .env).

# Connection string dari MongoDB Atlas (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/satria-toko-emas

# Password login halaman /admin
ADMIN_PASSWORD=ganti-password-ini

# Kunci acak untuk enkripsi sesi login — isi string acak apa saja, panjang, dan rahasia
SESSION_SECRET=ganti-dengan-string-acak-panjang
